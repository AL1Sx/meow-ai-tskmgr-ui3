<Page
    x:Class="meow_ai_tskmgr_ui3.Pages.ProcessListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Style="{StaticResource SectionHeaderStyle}"
            Text="进程列表" />

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                Header="搜索进程"
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Grid.Column="1"
                AutomationProperties.AutomationId="BtnRefreshProcesses"
                VerticalAlignment="Bottom"
                Command="{x:Bind ViewModel.LoadProcessesCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="刷新" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="2"
                AutomationProperties.AutomationId="BtnQueryProcess"
                VerticalAlignment="Bottom"
                Command="{x:Bind ViewModel.QueryProcessCommand}"
                CommandParameter="{x:Bind ViewModel.SearchQuery}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE99A;" FontSize="14" />
                    <TextBlock Text="AI 查询" />
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 表头 -->
                <Grid Grid.Row="0" ColumnSpacing="12" Padding="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="PID" />
                    <TextBlock
                        Grid.Column="1"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="进程名" />
                    <TextBlock
                        Grid.Column="2"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Right"
                        Text="内存" />
                    <TextBlock
                        Grid.Column="3"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Right"
                        Text="CPU%" />
                </Grid>

                <!-- 进程列表 -->
                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProcessInfo"
                                      xmlns:models="using:meow_ai_tskmgr_ui3.Models">
                            <Grid ColumnSpacing="12" Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{x:Bind Pid}" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Name}" />
                                <TextBlock
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    Text="{x:Bind RamMB, Converter={StaticResource UInt64ToStringConverter}}" />
                                <TextBlock
                                    Grid.Column="3"
                                    HorizontalAlignment="Right"
                                    Text="{x:Bind CpuPercent, Converter={StaticResource FloatToStringConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <TextBlock
            Grid.Row="3"
            FontSize="12"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            Text="{x:Bind ViewModel.ProcessCountText, Mode=OneWay}" />
    </Grid>
</Page>
