<Page
    x:Class="meow_ai_tskmgr_ui3.Pages.HardwareInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">
            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="硬件信息" />

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="计算机名" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.MachineName, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="操作系统" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.OsInfo, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="CPU" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.CpuName, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="GPU" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.GpuName, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="内存" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.RamInfo, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="主板" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.MotherboardInfo, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="硬盘" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.DiskInfo, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 锐评配置 -->
            <Button
                AutomationProperties.AutomationId="BtnCritiqueConfig"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CritiqueConfigCommand}"
                IsEnabled="{x:Bind ViewModel.IsCritiquing, Converter={StaticResource BoolNegationConverter}, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE99A;" FontSize="14" />
                    <TextBlock Text="🐱 锐评配置" />
                    <ProgressRing
                        Width="16"
                        Height="16"
                        IsActive="{x:Bind ViewModel.IsCritiquing, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsCritiquing, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                </StackPanel>
            </Button>

            <Border
                Style="{StaticResource CardBorderStyle}"
                Visibility="{x:Bind ViewModel.ConfigCritique, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                <StackPanel Spacing="8">
                    <TextBlock
                        Style="{StaticResource CardTitleStyle}"
                        Text="猫娘锐评" />
                    <TextBlock
                        FontSize="14"
                        LineHeight="22"
                        Text="{x:Bind ViewModel.ConfigCritique, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
