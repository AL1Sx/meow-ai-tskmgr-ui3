<Page
    x:Class="meow_ai_tskmgr_ui3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">
            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="API 设置" />

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="API 端点" />
                        <TextBox
                            HorizontalAlignment="Stretch"
                            Text="{x:Bind ViewModel.ApiEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="API 密钥" />
                        <PasswordBox
                            HorizontalAlignment="Stretch"
                            Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="模型" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                            SelectedIndex="{x:Bind ViewModel.ModelIndex, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName" />
                        <TextBox
                            HorizontalAlignment="Stretch"
                            PlaceholderText="输入兼容的模型名称"
                            Text="{x:Bind ViewModel.CustomModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{x:Bind ViewModel.IsCustomModel, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="外观" />

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="主题模式" />
                    <RadioButtons
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                        SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="监控设置" />

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="AI 分析间隔（分钟）" />
                    <NumberBox
                        HorizontalAlignment="Stretch"
                        Maximum="60"
                        Minimum="1"
                        Value="{x:Bind ViewModel.AnalysisInterval, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="硬件信息显示" />

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <CheckBox
                        Content="显示 CPU 型号"
                        IsChecked="{x:Bind ViewModel.ShowCpuName, Mode=TwoWay}" />
                    <CheckBox
                        Content="显示 GPU 型号"
                        IsChecked="{x:Bind ViewModel.ShowGpuName, Mode=TwoWay}" />
                    <CheckBox
                        Content="显示内存详情"
                        IsChecked="{x:Bind ViewModel.ShowRamDetail, Mode=TwoWay}" />
                    <CheckBox
                        Content="显示主板型号"
                        IsChecked="{x:Bind ViewModel.ShowMotherboard, Mode=TwoWay}" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="GPU 选择（如果有多个）" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.AvailableGpus, Mode=OneWay}"
                            SelectedIndex="{x:Bind ViewModel.GpuIndex, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button
                AutomationProperties.AutomationId="BtnSaveSettings"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.SaveSettingsCommand}"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74E;" FontSize="14" />
                    <TextBlock Text="保存设置" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</Page>
