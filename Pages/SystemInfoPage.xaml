<Page
    x:Class="meow_ai_tskmgr_ui3.Pages.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">
            <!-- 硬件信息 -->
            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="硬件信息" />

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="计算机名" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.MachineName, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="操作系统" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.OsInfo, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="CPU" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.CpuName, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="GPU" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.GpuName, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="内存" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.RamInfo, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="主板" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.MotherboardInfo, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="硬盘" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.DiskInfo, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 进程列表 -->
            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="进程列表" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Header="搜索进程"
                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.LoadProcessesCommand}"
                    Content="刷新" />
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.QueryProcessCommand}"
                    CommandParameter="{x:Bind ViewModel.SearchQuery}"
                    Content="AI 查询" />
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 表头 -->
                    <Grid Grid.Row="0" ColumnSpacing="12" Padding="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="PID" />
                        <TextBlock
                            Grid.Column="1"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="进程名" />
                        <TextBlock
                            Grid.Column="2"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Right"
                            Text="内存" />
                        <TextBlock
                            Grid.Column="3"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Right"
                            Text="CPU%" />
                    </Grid>

                    <!-- 进程列表 -->
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}"
                        SelectionMode="Single"
                        MaxHeight="400">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProcessInfo"
                                          xmlns:models="using:meow_ai_tskmgr_ui3.Models">
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{x:Bind Pid}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Name}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        Text="{x:Bind RamMB, Converter={StaticResource UInt64ToStringConverter}}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        HorizontalAlignment="Right"
                                        Text="{x:Bind CpuPercent, Converter={StaticResource FloatToStringConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="{x:Bind ViewModel.ProcessCountText, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
